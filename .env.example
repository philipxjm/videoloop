# VideoLoop environment variables. Copy to .env and fill in your keys.

# Google Gemini API key (https://aistudio.google.com/apikey).
# Used by all components (main agent, memory orchestrator) by default.
GEMINI_API_KEY=

# --- Optional per-component overrides ---------------------------------------
# Main agent: override the key and/or point at any OpenAI-compatible endpoint.
# MAIN_AGENT_API_KEY=
# MAIN_AGENT_API_BASE=

# Memory orchestrator / summarizer: defaults to the main agent's credentials.
# SUMMARIZER_API_KEY=
# SUMMARIZER_API_BASE=

# HuggingFace token for dataset downloads (scripts/prepare_*.py).
# HF_TOKEN=
