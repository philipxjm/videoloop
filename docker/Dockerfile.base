# Video Understanding Agent - BASE IMAGE
# Contains: CUDA, Python, all ML libraries, pre-downloaded models
# This takes ~10-15 minutes to build but rarely changes

FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

# Set non-interactive frontend for apt-get
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=America/Los_Angeles

# Set timezone
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# Install system dependencies
RUN apt-get update -y && apt-get upgrade -y && \
    apt-get install -y \
    # Core tools
    git curl wget build-essential ca-certificates software-properties-common \
    # Python
    python3.11 python3.11-venv python3.11-dev python3-pip \
    # Video/Audio processing
    ffmpeg libavcodec-dev libavformat-dev libswscale-dev libv4l-dev \
    libxvidcore-dev libx264-dev libjpeg-dev libpng-dev libtiff-dev \
    libatlas-base-dev gfortran \
    # Audio
    libsndfile1 portaudio19-dev sox libsox-fmt-all \
    # Image processing
    libopencv-dev tesseract-ocr tesseract-ocr-eng libtesseract-dev \
    # Additional libs
    libgl1-mesa-glx libglib2.0-0 libsm6 libxext6 libxrender-dev \
    # Useful utilities
    vim nano htop tree jq unzip \
    && rm -rf /var/lib/apt/lists/*

# Make python3.11 the default
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# Upgrade pip
RUN python -m pip install --upgrade pip setuptools wheel

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:/root/.cargo/bin:$PATH"

# Create working directories
RUN mkdir -p /testbed /videos /outputs /models

# ==============================================================================
# VIDEO PROCESSING LIBRARIES
# ==============================================================================

RUN pip install --no-cache-dir \
    opencv-python-headless==4.9.0.80 \
    decord==0.6.0 \
    imageio==2.34.0 \
    imageio-ffmpeg==0.4.9 \
    pillow==10.2.0 \
    scikit-image==0.22.0

# Scene detection
RUN pip install --no-cache-dir \
    scenedetect[opencv]==0.6.4

# Video utilities
RUN pip install --no-cache-dir \
    moviepy==1.0.3 \
    vidgear==0.3.3

# ==============================================================================
# AUDIO PROCESSING & ASR
# ==============================================================================

RUN pip install --no-cache-dir \
    pydub==0.25.1 \
    librosa==0.10.1 \
    soundfile==0.12.1 && \
    pip install --no-cache-dir --no-build-isolation openai-whisper==20231117

# ==============================================================================
# OCR & TEXT EXTRACTION
# ==============================================================================

RUN pip install --no-cache-dir \
    easyocr==1.7.1 \
    pytesseract==0.3.10 \
    pdf2image==1.17.0

# ==============================================================================
# OBJECT DETECTION & COMPUTER VISION
# ==============================================================================

RUN pip install --no-cache-dir \
    ultralytics==8.1.0 \
    supervision==0.19.0

# Install torch with CUDA
RUN pip install --no-cache-dir \
    torch==2.2.0 \
    torchvision==0.17.0 \
    torchaudio==2.2.0 \
    --index-url https://download.pytorch.org/whl/cu121

# ==============================================================================
# MACHINE LEARNING & DEEP LEARNING
# ==============================================================================

RUN pip install --no-cache-dir \
    transformers==4.38.0 \
    accelerate==0.27.0 \
    bitsandbytes==0.42.0 \
    sentencepiece==0.2.0 \
    einops==0.7.0

# ==============================================================================
# DATA PROCESSING & UTILITIES
# ==============================================================================

RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    pandas==2.2.0 \
    scipy==1.12.0 \
    matplotlib==3.8.3 \
    seaborn==0.13.2 \
    tqdm==4.66.2 \
    rich==13.7.0 \
    pyyaml==6.0.1 \
    python-dotenv==1.0.1 \
    httpx==0.27.0 \
    aiohttp==3.9.3 \
    requests==2.31.0

# ==============================================================================
# LLM/API INTEGRATION
# ==============================================================================

RUN pip install --no-cache-dir \
    openai==1.12.0 \
    anthropic==0.18.0 \
    litellm==1.28.0

# ==============================================================================
# DOWNLOAD MODELS (cached in base image)
# ==============================================================================

# Pre-download YOLO model
RUN python -c "from ultralytics import YOLO; YOLO('yolov8x.pt')"

# Pre-download Whisper tiny model (larger models downloaded on demand)
RUN python -c "import whisper; whisper.load_model('tiny')"

# Pre-download EasyOCR models
RUN python -c "import easyocr; easyocr.Reader(['en'], gpu=False, download_enabled=True)"

WORKDIR /testbed

# Label the base image
LABEL maintainer="video-understanding-agent"
LABEL version="1.0"
LABEL description="Base image with all ML dependencies for video understanding"
